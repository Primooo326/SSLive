# Application settings
PORT=3000

# MongoDB settings
# E.g., mongodb://localhost:27017/ssl-monitor
# If MONGODB_URI is left empty or not provided, the application will run in CLI standalone mode.
MONGODB_URI=mongodb://localhost:27017/ssl_cert_monitor

# Service settings
# How often to check all certificates (in milliseconds). Default is 1 hour (3600000 ms)
CHECK_INTERVAL_MS=3600000

# Default certificate warning/critical thresholds (in days)
WARN_DAYS=30
CRIT_DAYS=7
DEFAULT_PORT=443
